# Discord bot token from the Discord Developer Portal
DISCORD_TOKEN=

# Application (client) ID from the Discord Developer Portal
DISCORD_CLIENT_ID=

# Guild/server ID used for guild-scoped slash command deployment
DISCORD_GUILD_ID=

# PostgreSQL connection string used by Prisma
DATABASE_URL=

# Optional runtime environment (development|production)
NODE_ENV=development

# Optional log verbosity (trace|debug|info|warn|error|fatal)
LOG_LEVEL=info
