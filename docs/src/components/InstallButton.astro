---
import { buildInstallUrl } from "../config/site";

interface Props {
	label?: string;
}

const { label = "Install Gatekeeper" } = Astro.props;
const installUrl = buildInstallUrl();
---

<a class="install-button" href={installUrl} target="_blank" rel="noopener noreferrer">
	{label}
</a>

<style>
	.install-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.7rem 1rem;
		font-weight: 600;
		border-radius: 0.7rem;
		background: var(--sl-color-accent-high);
		color: var(--sl-color-black);
		text-decoration: none;
	}

	.install-button:hover {
		opacity: 0.9;
	}
</style>
